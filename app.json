{
  "expo": {
    "name": "NBE",
    "slug": "NBE-n-R4DF",
    "version": "1.0.30",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "nbe-n-r4df",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "ge.gov.nbe.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "ნება დართეთ აპს კამერის გამოყენება ვინაობის გადამოწმებისთვის.",
        "NSMicrophoneUsageDescription": "ნება დართეთ აპს მიკროფონის გამოყენება ვინაობის გადამოწმებისთვის."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "ge.gov.nbe.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ნება დართეთ აპს Face ID-ის გამოყენება სწრაფი ავტორიზაციისთვის."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f1b83546-5348-402e-af53-7a4375976c72"
      }
    },
    "owner": "infomygov",
    "updates": {
      "url": "https://u.expo.dev/f1b83546-5348-402e-af53-7a4375976c72"
    },
